{
  "buildCommand": "",
  "outputDirectory": ".",
  "installCommand": "npm install @napi-rs/canvas@1.0.0 @vercel/blob@2.4.0 ffmpeg-static@5.2.0 --include=optional --no-audit --no-fund",
  "functions": {
    "api/instagram-publish.js": {
      "maxDuration": 120
    },
    "api/instagram-reel.js": {
      "maxDuration": 250
    },
    "api/blob-upload-token.js": {
      "maxDuration": 60
    },
    "api/glossary-test.js": {
      "maxDuration": 60,
      "includeFiles": "node_modules/@napi-rs/canvas-linux-x64-gnu/**"
    },
    "api/glossary-cron.js": {
      "maxDuration": 300,
      "includeFiles": "node_modules/@napi-rs/canvas-linux-x64-gnu/**"
    },
    "api/specs-cron.js": {
      "maxDuration": 300,
      "includeFiles": "node_modules/@napi-rs/canvas-linux-x64-gnu/**"
    },
    "api/news-cron.js": {
      "maxDuration": 300,
      "includeFiles": "node_modules/@napi-rs/canvas-linux-x64-gnu/**"
    },
    "api/essay-cron.js": {
      "maxDuration": 300,
      "includeFiles": "node_modules/@napi-rs/canvas-linux-x64-gnu/**"
    },
    "api/corp-cron.js": {
      "maxDuration": 300,
      "includeFiles": "node_modules/@napi-rs/canvas-linux-x64-gnu/**"
    },
    "api/reel-cron.js": {
      "maxDuration": 300,
      "includeFiles": "node_modules/**"
    },
    "api/promo-reel.js": {
      "maxDuration": 300,
      "includeFiles": "node_modules/**"
    },
    "api/voice-reel.js": {
      "maxDuration": 300,
      "memory": 3008,
      "includeFiles": "node_modules/**"
    },
    "api/token-refresh-cron.js": {
      "maxDuration": 60
    },
    "api/blob-cleanup-cron.js": {
      "maxDuration": 60
    },
    "api/quiz-cron.js": {
      "maxDuration": 120
    },
    "api/spec-cron.js": {
      "maxDuration": 180
    },
    "api/thu-cron.js": {
      "maxDuration": 180
    },
    "api/mon-cron.js": {
      "maxDuration": 240
    },
    "api/reels60-cron.js": {
      "maxDuration": 300,
      "memory": 3008,
      "includeFiles": "node_modules/**"
    }
  },
  "crons": [
    {
      "path": "/api/glossary-cron",
      "schedule": "0 0 * * 1,3,5"
    },
    {
      "path": "/api/specs-cron",
      "schedule": "0 3 * * 0"
    },
    {
      "path": "/api/news-cron",
      "schedule": "0 0 * * 4"
    },
    {
      "path": "/api/reel-cron",
      "schedule": "0 9 * * 2,6"
    },
    {
      "path": "/api/essay-cron",
      "schedule": "0 0 * * 0"
    },
    {
      "path": "/api/corp-cron",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/token-refresh-cron",
      "schedule": "0 18 * * 0"
    },
    {
      "path": "/api/blob-cleanup-cron",
      "schedule": "0 20 * * 0"
    },
    {
      "path": "/api/quiz-cron?type=ncs",
      "schedule": "0 1 * * 2"
    },
    {
      "path": "/api/quiz-cron?type=law",
      "schedule": "0 1 * * 5"
    },
    {
      "path": "/api/spec-cron",
      "schedule": "0 1 * * 3"
    },
    {
      "path": "/api/thu-cron",
      "schedule": "0 10 * * 4"
    },
    {
      "path": "/api/mon-cron",
      "schedule": "0 10 * * 1"
    },
    {
      "path": "/api/reels60-cron",
      "schedule": "0 3 * * *"
    }
  ]
}