{
  "buildCommand": "",
  "outputDirectory": ".",
  "installCommand": "npm install @napi-rs/canvas@1.0.0 @vercel/blob@2.4.0 ffmpeg-static@5.2.0 --include=optional --no-audit --no-fund",
  "functions": {
    "api/instagram-publish.js": { "maxDuration": 120 },
    "api/instagram-reel.js": { "maxDuration": 250 },
    "api/blob-upload-token.js": { "maxDuration": 60 },
    "api/glossary-test.js": { "maxDuration": 60, "includeFiles": "node_modules/@napi-rs/canvas-linux-x64-gnu/**" },
    "api/glossary-cron.js": { "maxDuration": 300, "includeFiles": "node_modules/@napi-rs/canvas-linux-x64-gnu/**" },
    "api/specs-cron.js": { "maxDuration": 300, "includeFiles": "node_modules/@napi-rs/canvas-linux-x64-gnu/**" },
    "api/news-cron.js": { "maxDuration": 300, "includeFiles": "node_modules/@napi-rs/canvas-linux-x64-gnu/**" },
    "api/essay-cron.js": { "maxDuration": 300, "includeFiles": "node_modules/@napi-rs/canvas-linux-x64-gnu/**" },
    "api/reel-cron.js": { "maxDuration": 300, "includeFiles": "node_modules/**" },
    "api/token-refresh-cron.js": { "maxDuration": 60 }
  },
  "crons": [
    { "path": "/api/glossary-cron", "schedule": "0 0 * * 1,3,5" },
    { "path": "/api/specs-cron", "schedule": "0 3 * * 0" },
    { "path": "/api/news-cron", "schedule": "0 0 * * 4" },
    { "path": "/api/reel-cron", "schedule": "0 9 * * 2,6" },
    { "path": "/api/essay-cron", "schedule": "0 0 * * 0" },
    { "path": "/api/token-refresh-cron", "schedule": "0 18 * * 0" }
  ]
}
